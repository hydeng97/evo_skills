{
  "skill_id": "{{skill_id}}",
  "display_name": "{{display_name}}",
  "source_id": "{{source_id}}",
  "content_type": "{{content_type}}",
  "tags": ["{{tag_1}}", "{{tag_2}}"],
  "topic_tags": ["{{topic_tag_1}}"],
  "supported_modes": ["teach", "coach", "reflect"],
  "execution_level": "{{execution_level}}",
  "status": "draft",
  "version": "v1",
  "memory_enabled": true,
  "memory_runtime": {
    "enabled": true,
    "read_by_mode": {
      "teach": ["profile"],
      "coach": ["profile", "progress"],
      "reflect": ["profile", "progress", "sessions"],
      "execute": ["profile"]
    },
    "write_triggers": ["{{write_trigger_1}}"],
    "write_targets": {
      "profile": ["{{profile_target_1}}"],
      "progress": ["{{progress_target_1}}"],
      "sessions": ["{{sessions_target_1}}"]
    },
    "paths": {
      "shared_dir": "memory/{{skill_id}}/shared",
      "users_dir": "memory/{{skill_id}}/users"
    }
  },
  "article_runtime": {
    "paths": {
      "source_meta_json": "articles/{{source_id}}/source_meta.json",
      "distilled_md": "articles/{{source_id}}/distilled.md",
      "examples_md": "articles/{{source_id}}/examples.md",
      "coach_notes_md": "articles/{{source_id}}/coach_notes.md"
    },
    "read_by_mode": {
      "teach": ["distilled_md", "examples_md"],
      "coach": ["distilled_md", "coach_notes_md", "examples_md"],
      "reflect": ["distilled_md", "coach_notes_md"],
      "execute": []
    },
    "required_by_mode": {
      "teach": ["distilled_md"],
      "coach": ["distilled_md", "coach_notes_md"],
      "reflect": ["distilled_md"],
      "execute": []
    }
  },
  "exportable": true,
  "entry_path": "skills/{{skill_id}}/SKILL.md"
}
